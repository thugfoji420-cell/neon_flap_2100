<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for Android 12+ (API 31).
  Game data (coins, settings, unlocks) is stored in SharedPreferences and
  mirrored to Firestore. We disable cloud backup to prevent stale local data
  from overriding the authoritative cloud state during device restore.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="nf_" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="nf_" />
    </device-transfer>
</data-extraction-rules>
